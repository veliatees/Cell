  "reported_associations": [
    {
      "id": "cyp1a2_and_cyp3a4_activity_vs_matched_mrna",
      "finding": "Both SCR and MFR were reported as highly correlated with matched CYP1A2 and CYP3A4 mRNA levels.",
      "numeric_r_published_in_machine_readable_table": false,
      "model_consequence": "Association does not identify an expression-to-activity rate law."
    },
    {
      "id": "purity_and_albumin_vs_cyp_activity",
      "finding": "No significant associations were reported between CYP activities and ALB-positive fraction, HNF4A-positive fraction, scRNA hepatocyte fraction, or secreted albumin.",
      "numeric_r_published_in_machine_readable_table": false,
      "model_consequence": "Do not use a purity marker or albumin secretion as a numeric CYP activity proxy."
    }
  ],
  "required_measurements": [
    {
      "id": "raw_substrate_product_timecourses",
      "requirements": ["all sampled times", "substrate and product concentrations", "LLOQ and censoring flags", "incubation volume and viable-cell denominator"],
      "purpose": "Recompute SCR and MFR without reverse-engineering endpoint tables."
    },
    {
      "id": "matched_donor_genotype_protein_activity",
      "requirements": ["CYP genotype and copy number", "absolute CYP and POR protein abundance", "same-batch SCR and MFR"],
      "purpose": "Explain donor variation without treating batch means as a universal hepatocyte."
    },
    {
      "id": "matched_perturbation_timecourse",
      "requirements": ["selective inhibition or induction", "vehicle control", "viability", "time-resolved substrate and product"],
      "purpose": "Identify causal enzyme-specific response kinetics."
    }
